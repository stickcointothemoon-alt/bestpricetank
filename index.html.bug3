<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover"/>
<title>BestPriceTank 2.0</title>
<!-- Leaflet CSS loaded dynamically when online -->
<style>
:root{
  --void:#020812;--glass:rgba(5,12,28,.82);--glass2:rgba(8,18,40,.75);
  --rim:rgba(255,255,255,.09);--rim2:rgba(255,255,255,.17);
  --text:#eef2ff;--muted:rgba(170,190,240,.62);--faint:rgba(130,155,210,.35);
  --green:#00e676;--green2:rgba(0,230,118,.15);
  --blue:#448aff;--purple:#7c4dff;--amber:#ffab00;--red:#ff5252;--cyan:#00e5ff;
  --purple-g:rgba(124,77,255,.22);--green-g:rgba(0,230,118,.18);
  --sans:-apple-system,BlinkMacSystemFont,"SF Pro Display","Segoe UI",sans-serif;
  --mono:"SF Mono","Fira Code",monospace;
  --spring:cubic-bezier(0.34,1.56,0.64,1);
  --smooth:cubic-bezier(0.4,0,0.2,1);
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{width:100%;height:100dvh;overflow:hidden;font-family:var(--sans);color:var(--text);background:var(--void);-webkit-font-smoothing:antialiased}
button{cursor:pointer;border:none;background:none;font:inherit;color:inherit}
input,select{font:inherit;color:inherit;border:none;outline:none;background:none}
select option{background:#0a1628}

/* ─── MAP ─── */
#map{position:fixed;inset:0;z-index:0;background:#020812}
.leaflet-container{background:#020812}
/* Hide leaflet attribution (keep it readable but small) */
.leaflet-control-attribution{font-size:9px!important;background:rgba(0,0,0,.5)!important;color:rgba(255,255,255,.4)!important}
.leaflet-control-attribution a{color:rgba(255,255,255,.4)!important}

/* ─── PRICE BUBBLE MARKERS ─── */
.bub{
  display:flex;align-items:center;gap:6px;
  height:34px;padding:0 11px 0 7px;
  border-radius:999px;border:1.5px solid;
  backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);
  font:800 13px var(--mono);white-space:nowrap;
  box-shadow:0 6px 24px rgba(0,0,0,.5);
  cursor:pointer;transition:transform .2s var(--spring);
  animation:bub-float 4s ease infinite;
}
.bub:hover{transform:scale(1.12)!important;z-index:999}
.bub-logo{width:22px;height:22px;border-radius:50%;display:grid;place-items:center;font-size:10px;font-weight:900;flex-shrink:0}
.bub-de{background:rgba(20,50,120,.7);border-color:rgba(68,138,255,.5);color:#93c5fd}
.bub-de .bub-logo{background:#2563eb;color:#fff}
.bub-pl{background:rgba(0,40,15,.7);border-color:rgba(0,200,83,.45);color:#6ee7b7}
.bub-pl .bub-logo{background:#16a34a;color:#fff}
.bub-cz{background:rgba(50,20,0,.7);border-color:rgba(255,171,0,.4);color:#fcd34d}
.bub-cz .bub-logo{background:#b45309;color:#fff}
.bub-best::after{content:"★";position:absolute;top:-7px;right:-4px;width:16px;height:16px;border-radius:50%;background:var(--green);display:grid;place-items:center;font-size:9px;color:#012e0a;font-weight:900;box-shadow:0 0 12px var(--green);animation:star-spin 3s ease infinite}
.bub-best{position:relative}
@keyframes bub-float{0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)}}
@keyframes star-spin{0%,100%{transform:rotate(0)scale(1)}50%{transform:rotate(15deg)scale(1.15)}}
.leaflet-marker-icon{border:none!important;background:none!important}

/* Border glow polyline done via Leaflet SVG */

/* ─── UI LAYER ─── */
.ui{position:fixed;inset:0;z-index:10;pointer-events:none}
.ui>*{pointer-events:all}

/* ─── HEADER PILL ─── */
.hdr{
  position:absolute;top:max(env(safe-area-inset-top),10px);left:50%;
  transform:translateX(-50%);
  display:flex;align-items:center;gap:4px;
  height:48px;padding:0 6px;
  border-radius:999px;border:1px solid var(--rim2);
  background:var(--glass);
  backdrop-filter:blur(28px) saturate(180%);-webkit-backdrop-filter:blur(28px) saturate(180%);
  box-shadow:0 8px 40px rgba(0,0,0,.55),inset 0 1px 0 rgba(255,255,255,.05);
  animation:drop .6s var(--spring) both;
}
@keyframes drop{from{opacity:0;transform:translateX(-50%) translateY(-16px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}
.logo-pill{display:flex;align-items:center;gap:8px;padding:0 8px 0 4px}
.logo-ico{width:32px;height:32px;border-radius:10px;background:conic-gradient(from 180deg at 40% 40%,#ff6b1a,#ffd700,#ff6b1a);display:grid;place-items:center;font-size:16px;box-shadow:0 0 16px rgba(255,107,26,.3)}
.logo-txt{font-size:13.5px;font-weight:800;letter-spacing:-.2px}
.logo-txt em{color:#ff9d38;font-style:normal}
.hdiv{width:1px;height:28px;background:var(--rim)}
.hnav{display:flex;gap:2px}
.hbtn{height:36px;padding:0 12px;border-radius:999px;color:var(--muted);font-size:12px;font-weight:700;transition:all .18s;white-space:nowrap}
.hbtn:hover{color:var(--text);background:rgba(255,255,255,.06)}
.hbtn.on{color:#fff;background:rgba(124,77,255,.28);box-shadow:0 0 16px var(--purple-g)}
.hacts{display:flex;gap:4px}
.hico{width:34px;height:34px;border-radius:999px;border:1px solid var(--rim);display:grid;place-items:center;font-size:13px;transition:all .18s}
.hico:hover{background:rgba(255,255,255,.06)}
.nwrap{position:relative}
.ndot{position:absolute;top:2px;right:2px;width:8px;height:8px;border-radius:50%;background:var(--red);border:1.5px solid var(--void);box-shadow:0 0 8px var(--red);animation:npulse 2s ease infinite}
@keyframes npulse{0%,100%{transform:scale(1)}50%{transform:scale(1.4)}}
.langpill{display:flex;gap:3px;padding:3px;border:1px solid var(--rim);border-radius:999px;background:rgba(255,255,255,.04)}
.lbtn{height:24px;min-width:32px;border-radius:999px;font:700 11px var(--mono);color:var(--muted)}
.lbtn.on{background:rgba(124,77,255,.35);color:#fff}

/* ─── LIVE ─── */
.live-badge{
  position:absolute;top:calc(max(env(safe-area-inset-top),10px) + 58px);left:50%;transform:translateX(-50%);
  display:flex;align-items:center;gap:6px;height:22px;padding:0 9px;
  border-radius:999px;border:1px solid rgba(0,230,118,.22);background:rgba(0,230,118,.07);
  backdrop-filter:blur(12px);font:800 9px var(--mono);color:var(--green);letter-spacing:1.5px;
  animation:drop .7s .1s var(--spring) both;
}
.ldot{width:6px;height:6px;border-radius:50%;background:var(--green);box-shadow:0 0 10px var(--green);animation:lb 2s ease infinite}
@keyframes lb{0%,100%{opacity:1}50%{opacity:.25}}

/* ─── AI CARD ─── */
.ai-card{
  position:absolute;top:calc(max(env(safe-area-inset-top),10px) + 88px);left:16px;
  width:min(300px,calc(50vw - 24px));
  border-radius:20px;border:1px solid rgba(124,77,255,.28);
  background:var(--glass);
  backdrop-filter:blur(28px) saturate(160%);-webkit-backdrop-filter:blur(28px) saturate(160%);
  box-shadow:0 20px 60px rgba(0,0,0,.55),0 0 40px rgba(124,77,255,.1);
  overflow:hidden;animation:sil .7s .2s var(--spring) both;
}
@keyframes sil{from{opacity:0;transform:translateX(-24px)}to{opacity:1;transform:none}}
.aic-top{padding:12px 14px 10px;background:linear-gradient(135deg,rgba(124,77,255,.14),rgba(0,229,255,.05));border-bottom:1px solid var(--rim)}
.ai-badge{display:inline-flex;align-items:center;gap:5px;font:800 9px var(--mono);color:var(--cyan);letter-spacing:1.5px;margin-bottom:7px}
.ai-av{width:14px;height:14px;border-radius:4px;background:linear-gradient(135deg,var(--cyan),var(--purple));display:grid;place-items:center;font-size:8px}
.ai-hl{font-size:15px;font-weight:900;letter-spacing:-.4px;line-height:1.18}
.ai-hl strong{background:linear-gradient(90deg,var(--green),var(--cyan));-webkit-background-clip:text;background-clip:text;color:transparent}
.aic-body{padding:10px 14px 12px;display:grid;gap:6px}
.ai-row{display:flex;align-items:center;gap:7px;font-size:11.5px;font-weight:700;color:var(--muted)}
.ai-ri{width:20px;height:20px;border-radius:6px;display:grid;place-items:center;font-size:11px;flex-shrink:0}
.ai-cta{width:100%;height:34px;border-radius:11px;margin-top:3px;background:linear-gradient(135deg,var(--purple),var(--blue));color:#fff;font:800 12px var(--sans);display:flex;align-items:center;justify-content:center;gap:5px;box-shadow:0 6px 20px var(--purple-g);transition:all .2s var(--spring)}
.ai-cta:hover{transform:translateY(-1px);box-shadow:0 10px 28px var(--purple-g)}

/* ─── SIDE PANELS ─── */
.side-panel{
  position:fixed;top:0;right:0;bottom:0;
  width:min(440px,100vw);
  border-left:1px solid var(--rim2);
  background:var(--glass2);
  backdrop-filter:blur(32px) saturate(180%);-webkit-backdrop-filter:blur(32px) saturate(180%);
  box-shadow:-16px 0 80px rgba(0,0,0,.6);
  transform:translateX(100%);transition:transform .4s var(--spring);
  display:flex;flex-direction:column;z-index:30;pointer-events:none;
}
.side-panel.open{transform:none;pointer-events:all}
.pnl-head{padding:16px 18px;border-bottom:1px solid var(--rim);display:flex;align-items:center;gap:10px;flex-shrink:0}
.pnl-head h2{font-size:20px;font-weight:900;letter-spacing:-.5px;flex:1}
.pnl-head p{font-size:12px;color:var(--muted)}
.pclose{width:36px;height:36px;border-radius:999px;border:1px solid var(--rim);background:rgba(255,255,255,.06);display:grid;place-items:center;font-size:18px;color:var(--muted);flex-shrink:0}
.pbody{flex:1;overflow-y:auto;padding:18px;display:grid;gap:13px;align-content:start;scrollbar-width:thin;scrollbar-color:rgba(255,255,255,.08) transparent}

/* Tabs inside panel */
.tab-row{display:flex;gap:4px;padding:4px;border-radius:14px;border:1px solid var(--rim);background:rgba(255,255,255,.04)}
.tab{height:34px;border-radius:10px;flex:1;color:var(--muted);font:800 12px var(--sans);transition:all .18s;white-space:nowrap}
.tab.on{color:#fff;background:rgba(124,77,255,.28)}

/* ─── FORM ELEMENTS ─── */
.fl{font:800 10px var(--mono);letter-spacing:1.5px;color:var(--faint);text-transform:uppercase;margin-bottom:5px;display:block}
.fi{width:100%;height:46px;border-radius:13px;border:1px solid var(--rim);background:rgba(255,255,255,.06);color:var(--text);padding:0 13px;font:700 14px var(--sans);transition:border-color .15s}
.fi:focus{border-color:rgba(124,77,255,.5);background:rgba(124,77,255,.06)}
.fi::placeholder{color:var(--faint)}
.fsel{width:100%;height:46px;border-radius:13px;border:1px solid var(--rim);background:rgba(255,255,255,.06);color:var(--text);padding:0 13px;font:700 14px var(--sans);-webkit-appearance:none;cursor:pointer}
.fg2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.frange{width:100%;height:6px;-webkit-appearance:none;border-radius:3px;background:rgba(255,255,255,.1);accent-color:var(--purple);cursor:pointer}
.frange::-webkit-slider-thumb{-webkit-appearance:none;width:22px;height:22px;border-radius:50%;background:linear-gradient(135deg,var(--purple),var(--blue));box-shadow:0 4px 12px var(--purple-g);border:3px solid rgba(255,255,255,.9)}

/* ─── RESULT HERO ─── */
.rhero{border-radius:18px;padding:18px;background:linear-gradient(135deg,rgba(0,200,83,.12),rgba(0,229,255,.05));border:1px solid rgba(0,230,118,.2)}
.rlabel{font:800 9px var(--mono);letter-spacing:2px;color:var(--green);margin-bottom:5px;text-transform:uppercase}
.rnum{font-size:50px;font-weight:900;letter-spacing:-3px;line-height:1;background:linear-gradient(90deg,var(--green),var(--cyan));-webkit-background-clip:text;background-clip:text;color:transparent}
.rsub{font-size:12.5px;color:var(--muted);margin-top:4px}
.rdets{display:flex;gap:14px;margin-top:10px;flex-wrap:wrap}
.rdet{font-size:11.5px;color:var(--muted)}
.rdet strong{color:var(--text);margin-left:3px}

/* ─── COMPARE ─── */
.cmp{border-radius:14px;border:1px solid var(--rim);background:rgba(255,255,255,.03);overflow:hidden}
.cmp-row{display:flex;align-items:center;gap:9px;padding:11px 13px;border-bottom:1px solid var(--rim)}
.cmp-row:last-child{border:none}
.cflag{width:26px;font-size:18px;text-align:center}
.cn{flex:1}
.cn b{display:block;font-size:13px;font-weight:800}
.cn small{font-size:11px;color:var(--muted)}
.cprice{font:900 17px var(--mono);letter-spacing:-.5px}
.csave{padding:2px 7px;border-radius:999px;font:800 11px var(--mono)}
.csave.good{color:var(--green);background:rgba(0,230,118,.1);border:1px solid rgba(0,230,118,.18)}

/* ─── TAX BARS ─── */
.tbar-row{display:grid;gap:10px}
.tbar{display:grid;gap:5px}
.tbar-label{display:flex;justify-content:space-between;align-items:baseline}
.tbar-name{font-size:13px;font-weight:800;display:flex;align-items:center;gap:6px}
.tbar-price{font:900 17px var(--mono)}
.tbar-track{height:14px;border-radius:7px;background:rgba(255,255,255,.06);overflow:hidden;display:flex}
.tbar-net{height:100%;background:linear-gradient(90deg,#00e676,#00b0ff);transition:width .8s var(--spring)}
.tbar-tax{height:100%;background:linear-gradient(90deg,#ff6d00,#ff1744);transition:width .8s var(--spring)}
.tbar-meta{font-size:11px;color:var(--muted);font-weight:700}

/* ─── EV ─── */
.ev-result{border-radius:18px;padding:18px;border:1px solid var(--rim);background:rgba(255,255,255,.03)}
.ev-vs{display:grid;grid-template-columns:1fr auto 1fr;gap:10px;align-items:center;text-align:center}
.ev-item{padding:12px;border-radius:14px;border:1px solid var(--rim);background:rgba(255,255,255,.04)}
.ev-item-label{font:800 9px var(--mono);letter-spacing:1.5px;color:var(--faint);margin-bottom:5px}
.ev-item-val{font-size:22px;font-weight:900;letter-spacing:-1px}
.ev-vs-sep{font:900 20px var(--sans);color:var(--faint)}
.ev-diff{font-size:13px;font-weight:800;padding:5px 10px;border-radius:999px;margin:8px auto 0;display:inline-block}
.ev-good{color:var(--green);background:rgba(0,230,118,.1);border:1px solid rgba(0,230,118,.18)}
.ev-bad{color:#fca5a5;background:rgba(255,82,82,.08);border:1px solid rgba(255,82,82,.18)}
.ev-note{font-size:12px;color:var(--muted);padding:10px 12px;border-radius:12px;border:1px solid rgba(255,171,0,.18);background:rgba(255,171,0,.07)}

/* ─── STATION PANEL ─── */
.spanel{
  position:fixed;bottom:76px;left:50%;transform:translateX(-50%) translateY(calc(100% + 16px));
  width:min(440px,calc(100vw - 28px));
  border-radius:22px;border:1px solid var(--rim2);
  background:var(--glass2);backdrop-filter:blur(28px);-webkit-backdrop-filter:blur(28px);
  box-shadow:0 -8px 60px rgba(0,0,0,.6);overflow:hidden;
  transition:transform .4s var(--spring),opacity .3s;opacity:0;pointer-events:none;z-index:20;
}
.spanel.open{transform:translateX(-50%) translateY(0);opacity:1;pointer-events:all}
.sph{padding:15px 16px 13px;border-bottom:1px solid var(--rim);display:flex;align-items:center;gap:10px}
.splogo{width:42px;height:42px;border-radius:13px;border:1px solid var(--rim2);display:grid;place-items:center;font-size:18px;font-weight:900;flex-shrink:0}
.spname{font-size:16px;font-weight:900;letter-spacing:-.3px}
.spmeta{font-size:11.5px;color:var(--muted);margin-top:2px;display:flex;align-items:center;gap:5px}
.spx{width:30px;height:30px;border-radius:999px;border:1px solid var(--rim);background:rgba(255,255,255,.06);display:grid;place-items:center;font-size:16px;color:var(--muted);margin-left:auto;flex-shrink:0}
.spb{padding:14px 16px;display:grid;gap:10px}
.sp-prices{display:grid;grid-template-columns:repeat(4,1fr);gap:6px}
.spp{text-align:center;padding:9px 4px;border-radius:13px;border:1px solid var(--rim);background:rgba(255,255,255,.04);cursor:pointer;transition:all .18s}
.spp.on{background:rgba(0,230,118,.1);border-color:rgba(0,230,118,.28)}
.spp-t{font:800 9px var(--mono);letter-spacing:.5px;color:var(--faint);margin-bottom:4px;text-transform:uppercase}
.spp-v{font-size:16px;font-weight:900;letter-spacing:-.3px}
.spp.on .spp-v{color:var(--green)}
.sp-stats{display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px}
.spstat{padding:9px;border-radius:13px;border:1px solid var(--rim);background:rgba(255,255,255,.03);text-align:center}
.spstat-l{font:700 9px var(--mono);color:var(--faint);margin-bottom:3px;letter-spacing:.5px;text-transform:uppercase}
.spstat-v{font-size:14px;font-weight:900}
.sp-acts{display:grid;grid-template-columns:1fr auto;gap:7px}
.btn-p{height:44px;border-radius:13px;background:linear-gradient(135deg,var(--purple),var(--blue));color:#fff;font:900 13px var(--sans);display:flex;align-items:center;justify-content:center;gap:5px;box-shadow:0 8px 24px var(--purple-g);transition:all .2s var(--spring)}
.btn-p:hover{transform:translateY(-1px);box-shadow:0 12px 32px var(--purple-g)}
.btn-s{height:44px;padding:0 14px;border-radius:13px;border:1px solid var(--rim2);background:rgba(255,255,255,.06);color:var(--text);font:800 13px var(--sans)}

/* ─── KI CHAT ─── */
.ki-msgs{flex:1;overflow-y:auto;padding:14px 18px;display:flex;flex-direction:column;gap:10px;scrollbar-width:thin;scrollbar-color:rgba(255,255,255,.07) transparent}
.mu{align-self:flex-end;max-width:84%;background:linear-gradient(135deg,rgba(124,77,255,.28),rgba(68,138,255,.18));border:1px solid rgba(124,77,255,.28);border-radius:15px 15px 3px 15px;padding:10px 13px;font-size:13.5px;font-weight:600;animation:mpop .25s var(--spring) both}
.ma{align-self:flex-start;max-width:93%;animation:mpop .25s var(--spring) both}
@keyframes mpop{from{opacity:0;transform:translateY(8px)scale(.96)}to{opacity:1;transform:none}}
.mai{background:rgba(255,255,255,.05);border:1px solid var(--rim2);border-radius:3px 15px 15px 15px;padding:11px 13px}
.mah{display:flex;align-items:center;gap:7px;margin-bottom:8px}
.mav{width:24px;height:24px;border-radius:8px;background:linear-gradient(135deg,var(--cyan),var(--purple));display:grid;place-items:center;font-size:12px;flex-shrink:0}
.man{font:800 10px var(--mono);color:var(--cyan)}
.mat{font-size:13px;line-height:1.5}
.mfs{display:grid;gap:4px;margin-top:8px}
.mf{display:flex;align-items:center;gap:6px;padding:6px 8px;border-radius:9px;background:rgba(255,255,255,.04);border:1px solid var(--rim);font-size:12px;font-weight:700}
.mfi{width:20px;height:20px;border-radius:6px;display:grid;place-items:center;font-size:11px;flex-shrink:0}
.typing{display:flex;align-items:center;gap:4px;padding:9px 13px;background:rgba(255,255,255,.05);border:1px solid var(--rim2);border-radius:3px 13px 13px 13px;width:fit-content}
.td{width:7px;height:7px;border-radius:50%;background:var(--cyan);animation:tb 1.2s ease infinite}
.td:nth-child(2){animation-delay:.15s}.td:nth-child(3){animation-delay:.3s}
@keyframes tb{0%,100%{transform:translateY(0);opacity:.4}50%{transform:translateY(-5px);opacity:1}}
.ki-inp{padding:12px 16px calc(env(safe-area-inset-bottom,0px) + 12px);border-top:1px solid var(--rim);flex-shrink:0}
.kibar{display:flex;gap:7px;align-items:center;padding:7px;border-radius:15px;border:1px solid var(--rim);background:rgba(255,255,255,.05)}
.kibar input{flex:1;height:36px;background:transparent;color:var(--text);padding:0 9px;font-size:13.5px;font-weight:600}
.kibar input::placeholder{color:var(--faint)}
.kisend{width:36px;height:36px;border-radius:9px;flex-shrink:0;background:linear-gradient(135deg,var(--purple),var(--blue));display:grid;place-items:center;font-size:15px;box-shadow:0 4px 14px var(--purple-g)}
.kimic{width:36px;height:36px;border-radius:9px;flex-shrink:0;border:1px solid var(--rim);background:rgba(255,255,255,.06);display:grid;place-items:center;font-size:15px}
.qqs{display:flex;gap:5px;flex-wrap:nowrap;overflow-x:auto;margin-top:8px;scrollbar-width:none;padding-bottom:1px}
.qqs::-webkit-scrollbar{display:none}
.qq{height:27px;padding:0 10px;border-radius:999px;flex-shrink:0;border:1px solid var(--rim);background:rgba(255,255,255,.05);color:var(--muted);font:800 11.5px var(--sans);transition:all .15s;white-space:nowrap}
.qq:hover{background:rgba(124,77,255,.15);color:#fff;border-color:rgba(124,77,255,.3)}

/* ─── NAV DOCK ─── */
.dock{
  position:fixed;bottom:calc(env(safe-area-inset-bottom,0px) + 14px);left:50%;transform:translateX(-50%);
  display:flex;gap:2px;padding:5px;
  border-radius:999px;border:1px solid var(--rim2);
  background:var(--glass);backdrop-filter:blur(28px) saturate(200%);-webkit-backdrop-filter:blur(28px) saturate(200%);
  box-shadow:0 16px 56px rgba(0,0,0,.65),inset 0 1px 0 rgba(255,255,255,.05);
  z-index:25;animation:dup .7s .3s var(--spring) both;
}
@keyframes dup{from{opacity:0;transform:translateX(-50%) translateY(18px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}
.dbtn{display:flex;flex-direction:column;align-items:center;gap:2px;padding:7px 14px;border-radius:999px;color:var(--muted);font-size:10px;font-weight:800;letter-spacing:.1px;transition:all .2s var(--spring);position:relative}
.dbtn:hover{color:var(--text)}
.dbtn.on{color:#fff;background:rgba(124,77,255,.28)}
.dico{font-size:17px;line-height:1;margin-bottom:1px}
.ddot{position:absolute;bottom:5px;left:50%;transform:translateX(-50%);width:4px;height:4px;border-radius:50%;background:var(--purple);opacity:0;transition:opacity .2s}
.dbtn.on .ddot{opacity:1}

/* ─── DIM ─── */
.dim{position:fixed;inset:0;z-index:15;background:rgba(2,6,16,.55);backdrop-filter:blur(3px);opacity:0;pointer-events:none;transition:opacity .3s}
.dim.show{opacity:1;pointer-events:all}

/* ─── MOBILE ─── */
@media(max-width:700px){
  .hnav,.hdiv{display:none}
  .hdr{width:calc(100vw - 24px)}
  .logo-pill{margin-right:0}
  .ai-card{width:calc(100vw - 32px);max-width:320px;top:calc(max(env(safe-area-inset-top),10px) + 80px)}
  .side-panel{width:100vw;border-left:none;border-top:1px solid var(--rim2);border-radius:22px 22px 0 0;top:auto;bottom:0;height:88dvh;transform:translateY(100%)}
  .side-panel.open{transform:none}
  .spanel{bottom:82px}
  .dbtn{padding:7px 10px}
}
@media(max-width:380px){.dbtn{padding:7px 8px;font-size:9px}.dico{font-size:15px}}

/* ─── TAB CONTENT ─── */
.tcontent{display:none}
.tcontent.on{display:grid;gap:13px}
</style>
</head>
<body>

<!-- MAP -->
<div id="map">
<!-- Static SVG map — always visible, Leaflet replaces when online -->
<svg id="map-svg" width="100%" height="100%" viewBox="0 0 1400 900" preserveAspectRatio="xMidYMid slice" style="display:block;position:absolute;inset:0">
  <defs>
    <radialGradient id="gde" cx="26%" cy="50%" r="70%">
      <stop offset="0%" stop-color="#1e3f72" stop-opacity=".95"/>
      <stop offset="100%" stop-color="#060e24" stop-opacity="1"/>
    </radialGradient>
    <radialGradient id="gpl" cx="68%" cy="38%" r="65%">
      <stop offset="0%" stop-color="#0d4225" stop-opacity=".95"/>
      <stop offset="100%" stop-color="#020d07" stop-opacity="1"/>
    </radialGradient>
    <radialGradient id="gcz" cx="48%" cy="82%" r="58%">
      <stop offset="0%" stop-color="#4a1212" stop-opacity=".92"/>
      <stop offset="100%" stop-color="#090202" stop-opacity="1"/>
    </radialGradient>
    <linearGradient id="gborder" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#7c4dff"/>
      <stop offset="35%" stop-color="#00e5ff"/>
      <stop offset="68%" stop-color="#00e676"/>
      <stop offset="100%" stop-color="#ffab00"/>
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="5" result="b"/>
      <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
    <filter id="glow-sm">
      <feGaussianBlur stdDeviation="2.5" result="b"/>
      <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
  </defs>
  <!-- Base -->
  <rect width="1400" height="900" fill="#020812"/>
  <!-- Country fills -->
  <path d="M0,0 L620,0 L590,240 L558,390 L522,530 L484,700 L448,900 L0,900Z" fill="url(#gde)"/>
  <path d="M620,0 L1400,0 L1400,560 L960,600 L780,555 L660,415 L600,248Z" fill="url(#gpl)"/>
  <path d="M448,900 L484,700 L522,530 L558,390 L660,415 L780,555 L960,600 L1400,560 L1400,900Z" fill="url(#gcz)"/>
  <!-- Topo DE -->
  <g opacity=".07" fill="none" stroke="#4488ff" stroke-width="1.3">
    <path d="M0,740 Q220,690 420,660 Q520,640 565,618"/>
    <path d="M0,560 Q200,525 370,502 Q480,486 560,460"/>
    <path d="M40,360 Q230,322 400,316 Q505,310 575,290"/>
    <path d="M0,180 Q180,148 340,158 Q455,166 585,145"/>
  </g>
  <!-- Topo PL -->
  <g opacity=".07" fill="none" stroke="#00c853" stroke-width="1.3">
    <path d="M670,85 Q850,62 1050,72 Q1220,80 1400,62"/>
    <path d="M648,218 Q828,192 1030,182 Q1210,174 1400,155"/>
    <path d="M672,368 Q852,342 1055,336 Q1228,330 1400,314"/>
    <path d="M720,488 Q900,472 1100,462 Q1270,454 1400,442"/>
  </g>
  <!-- Topo CZ -->
  <g opacity=".07" fill="none" stroke="#ff6d00" stroke-width="1.3">
    <path d="M454,800 Q640,778 820,760 Q990,744 1210,750 Q1330,752 1400,748"/>
    <path d="M490,658 Q672,636 855,620 Q1022,606 1230,610 Q1340,612 1400,608"/>
  </g>
  <!-- Border glow -->
  <path d="M590,240 L575,340 L558,440 L540,540 L522,640 L506,740 L488,860"
    stroke="url(#gborder)" stroke-width="3" fill="none" opacity=".9"
    stroke-dasharray="12 6"/>
  <path d="M590,240 L575,340 L558,440 L540,540 L522,640 L506,740 L488,860"
    stroke="url(#gborder)" stroke-width="16" fill="none" opacity=".13" filter="url(#glow)"/>
  <!-- City labels -->
  <text x="240" y="380" font-family="system-ui,sans-serif" font-size="26" font-weight="900"
    fill="rgba(100,160,255,.32)" letter-spacing="10" text-anchor="middle">DEUTSCHLAND</text>
  <text x="980" y="300" font-family="system-ui,sans-serif" font-size="26" font-weight="900"
    fill="rgba(0,200,83,.28)" letter-spacing="10" text-anchor="middle">POLEN</text>
  <text x="950" y="760" font-family="system-ui,sans-serif" font-size="26" font-weight="900"
    fill="rgba(255,100,80,.26)" letter-spacing="10" text-anchor="middle">TSCHECHIEN</text>
  <!-- City dots -->
  <circle cx="560" cy="388" r="13" fill="#7c4dff" opacity=".95" filter="url(#glow)"/>
  <circle cx="560" cy="388" r="28" fill="#7c4dff" opacity=".12"/>
  <circle cx="560" cy="388" r="46" fill="#7c4dff" opacity=".05"/>
  <text x="526" y="370" font-family="system-ui,sans-serif" font-size="15"
    font-weight="800" fill="rgba(255,255,255,.85)">Görlitz</text>
  <circle cx="622" cy="376" r="10" fill="#00e676" opacity=".95" filter="url(#glow)"/>
  <circle cx="622" cy="376" r="22" fill="#00e676" opacity=".1"/>
  <text x="638" y="372" font-family="system-ui,sans-serif" font-size="13"
    font-weight="800" fill="rgba(255,255,255,.75)">Zgorzelec</text>
  <circle cx="546" cy="558" r="9" fill="#ffab00" opacity=".95" filter="url(#glow)"/>
  <circle cx="546" cy="558" r="20" fill="#ffab00" opacity=".1"/>
  <text x="562" y="554" font-family="system-ui,sans-serif" font-size="13"
    font-weight="800" fill="rgba(255,255,255,.72)">Hrádek n.N.</text>
  <circle cx="720" cy="290" r="8" fill="#00c853" opacity=".8" filter="url(#glow-sm)"/>
  <text x="736" y="286" font-family="system-ui,sans-serif" font-size="12"
    font-weight="700" fill="rgba(255,255,255,.55)">Bogatynia</text>
  <circle cx="462" cy="510" r="8" fill="#448aff" opacity=".8" filter="url(#glow-sm)"/>
  <text x="398" y="506" font-family="system-ui,sans-serif" font-size="12"
    font-weight="700" fill="rgba(255,255,255,.55)">Zittau</text>
  <!-- Route hints -->
  <path d="M560,388 Q590,382 622,376" stroke="rgba(124,77,255,.45)"
    stroke-width="2.5" stroke-dasharray="5 4" fill="none"/>
  <path d="M560,388 Q553,473 546,558" stroke="rgba(255,171,0,.35)"
    stroke-width="2" stroke-dasharray="5 4" fill="none"/>
</svg>

<!-- Price Bubbles — static HTML over SVG -->
<div id="map-bubbles" style="position:absolute;inset:0;pointer-events:none">
  <!-- Shell Görlitz DE -->
  <div class="bub bub-de" style="position:absolute;left:32%;top:42%;animation-delay:.3s;pointer-events:all" onclick="openStation('shell')">
    <div class="bub-logo">🐚</div><span id="bub-shell-price">1,649°</span>
  </div>
  <!-- TotalEnergies DE -->
  <div class="bub bub-de" style="position:absolute;left:26%;top:52%;animation-delay:.8s;pointer-events:all" onclick="openStation('total')">
    <div class="bub-logo">T</div><span id="bub-total-price">1,659°</span>
  </div>
  <!-- Citronex PL — BEST -->
  <div class="bub bub-pl bub-best" style="position:absolute;left:47%;top:40%;animation-delay:.0s;pointer-events:all;z-index:5" onclick="openStation('citronex')">
    <div class="bub-logo">C</div><span id="bub-citronex-price">1,440°</span>
  </div>
  <!-- AB Tank PL -->
  <div class="bub bub-pl" style="position:absolute;left:53%;top:29%;animation-delay:1.1s;pointer-events:all" onclick="openStation('abtank')">
    <div class="bub-logo">AB</div><span id="bub-abtank-price">1,462°</span>
  </div>
  <!-- ORLEN PL -->
  <div class="bub bub-pl" style="position:absolute;left:58%;top:20%;animation-delay:.6s;pointer-events:all" onclick="openStation('orlen')">
    <div class="bub-logo">O</div><span id="bub-orlen-price">1,573°</span>
  </div>
  <!-- MOL CZ -->
  <div class="bub bub-cz" style="position:absolute;left:39%;top:63%;animation-delay:.4s;pointer-events:all" onclick="openStation('mol')">
    <div class="bub-logo">M</div><span id="bub-mol-price">1,477°</span>
  </div>
  <!-- EuroOil CZ -->
  <div class="bub bub-cz" style="position:absolute;left:44%;top:70%;animation-delay:.9s;pointer-events:all" onclick="openStation('eurooil')">
    <div class="bub-logo">E</div><span id="bub-eurooil-price">1,497°</span>
  </div>
</div>
</div>

<!-- UI -->
<div class="ui">

  <!-- Header -->
  <div class="hdr">
    <div class="logo-pill">
      <div class="logo-ico">⛽</div>
      <div class="logo-txt"><b>BestPrice</b><em>Tank</em></div>
    </div>
    <div class="hdiv"></div>
    <nav class="hnav">
      <button class="hbtn on" onclick="sv('home')">Start</button>
      <button class="hbtn" onclick="sv('stations')">Tankstellen</button>
      <button class="hbtn" onclick="sv('rechner')">Sparen</button>
      <button class="hbtn" onclick="sv('ki')">KI-Assist</button>
    </nav>
    <div class="hdiv"></div>
    <div class="hacts">
      <div class="langpill">
        <button class="lbtn on">DE</button>
        <button class="lbtn">PL</button>
        <button class="lbtn">CZ</button>
      </div>
      <div class="nwrap"><button class="hico">🔔</button><div class="ndot"></div></div>
      <button class="hico" id="themeBtn">🌙</button>
    </div>
  </div>

  <!-- Live -->
  <div class="live-badge"><div class="ldot"></div>LIVE · DREILÄNDERECK · 08:45 Uhr</div>

  <!-- AI card -->
  <div class="ai-card" id="aic">
    <div class="aic-top">
      <div class="ai-badge"><div class="ai-av">🤖</div>KI-ASSISTENT · HEUTE</div>
      <div class="ai-hl">Polen spart heute<br><strong id="ai-save">8,40 €</strong> bei 60L Diesel</div>
    </div>
    <div class="aic-body">
      <div class="ai-row"><div class="ai-ri" style="background:rgba(0,230,118,.15)">⛽</div>Citronex Zgorzelec — <b style="color:var(--green)">1,40 €/L</b></div>
      <div class="ai-row"><div class="ai-ri" style="background:rgba(68,138,255,.15)">📍</div>8,4 km · ca. 10 Min</div>
      <div class="ai-row"><div class="ai-ri" style="background:rgba(255,171,0,.15)">🌤</div>18°C · kein Stau · keine Baustellen</div>
      <button class="ai-cta" onclick="sv('rechner')">🚗 Fahrt berechnen →</button>
    </div>
  </div>

  <!-- Dock -->
  <div class="dock">
    <button class="dbtn on" id="d-home" onclick="sv('home')"><div class="dico">🏠</div>Start<div class="ddot"></div></button>
    <button class="dbtn" id="d-stations" onclick="sv('stations')"><div class="dico">⛽</div>Stationen<div class="ddot"></div></button>
    <button class="dbtn" id="d-rechner" onclick="sv('rechner')"><div class="dico">💰</div>Sparen<div class="ddot"></div></button>
    <button class="dbtn" id="d-ki" onclick="sv('ki')"><div class="dico">🤖</div>KI<div class="ddot"></div></button>
    <button class="dbtn" id="d-community" onclick="sv('community')"><div class="dico">📍</div>Community<div class="ddot"></div></button>
  </div>

</div><!-- /ui -->

<!-- DIM -->
<div class="dim" id="dim" onclick="closePanels()"></div>

<!-- STATION DETAIL PANEL -->
<div class="spanel" id="spanel">
  <div class="sph">
    <div class="splogo" id="sp-logo">C</div>
    <div>
      <div class="spname" id="sp-name">Citronex I, Zgorzelec</div>
      <div class="spmeta">🇵🇱 <span id="sp-dist">8,4 km</span> · <span style="color:var(--green);font-weight:900">● Geöffnet</span></div>
    </div>
    <button class="spx" onclick="closeStation()">×</button>
  </div>
  <div class="spb">
    <div class="sp-prices">
      <div class="spp on"><div class="spp-t">Diesel</div><div class="spp-v" id="spd">–</div></div>
      <div class="spp"><div class="spp-t">E5</div><div class="spp-v" id="spe5">–</div></div>
      <div class="spp"><div class="spp-t">E10</div><div class="spp-v" id="spe10">–</div></div>
      <div class="spp"><div class="spp-t">LPG</div><div class="spp-v" id="splpg">–</div></div>
    </div>
    <div class="sp-stats">
      <div class="spstat"><div class="spstat-l">Ersparnis</div><div class="spstat-v" id="spsave" style="color:var(--green)">–</div></div>
      <div class="spstat"><div class="spstat-l">Entfernung</div><div class="spstat-v" id="spdist2">–</div></div>
      <div class="spstat"><div class="spstat-l">Update</div><div class="spstat-v" style="font-size:12px">vor 8 Min</div></div>
    </div>
    <div class="sp-acts">
      <button class="btn-p" onclick="sv('rechner');closeStation()">🚗 Fahrt berechnen</button>
      <button class="btn-s">🗺</button>
    </div>
  </div>
</div>

<!-- STATIONEN SIDE PANEL -->
<div class="side-panel" id="panel-stations">
  <div class="pnl-head">
    <div><h2>Tankstellen</h2><p>Live · Dreiländereck</p></div>
    <button class="pclose" onclick="cp('stations')">×</button>
  </div>
  <div class="pbody">
    <div style="display:flex;gap:5px;flex-wrap:wrap">
      <button class="qq" style="background:rgba(124,77,255,.2);color:#fff;border-color:rgba(124,77,255,.35)">⛽ Diesel</button>
      <button class="qq">🟢 E5</button><button class="qq">🌿 E10</button><button class="qq">💧 LPG</button>
      <button class="qq" style="margin-left:auto">Alle Länder</button>
    </div>
    <!-- List -->
    <div style="display:grid;gap:5px" id="station-list-inner">
      <!-- rendered by JS -->
    </div>
    <div style="display:flex;align-items:center;gap:8px;padding:9px 11px;border-radius:12px;border:1px solid var(--rim);background:rgba(255,255,255,.03);font:700 10px var(--mono)">
      <span style="color:var(--muted)">Preis niedrig</span>
      <div style="flex:1;height:5px;border-radius:3px;background:linear-gradient(90deg,#00e676,#ffab00,#ff5252)"></div>
      <span style="color:var(--muted)">hoch</span>
    </div>
    <button style="width:100%;height:42px;border-radius:13px;border:1px solid rgba(124,77,255,.28);background:rgba(124,77,255,.1);color:#c4b5fd;font:800 13px var(--sans)">📍 Preis melden</button>
  </div>
</div>

<!-- RECHNER SIDE PANEL (3 tabs) -->
<div class="side-panel" id="panel-rechner">
  <div class="pnl-head">
    <div><h2>Sparen</h2><p>Grenz-, Steuer- & E-Auto-Rechner</p></div>
    <button class="pclose" onclick="cp('rechner')">×</button>
  </div>
  <div class="pbody">
    <!-- Tabs -->
    <div class="tab-row">
      <button class="tab on" onclick="showTab('border')">🚗 Grenze</button>
      <button class="tab" onclick="showTab('tax')">🧮 Steuer</button>
      <button class="tab" onclick="showTab('ev')">⚡ E-Auto</button>
    </div>

    <!-- TAB: Grenzrechner -->
    <div class="tcontent on" id="tab-border">
      <div>
        <label class="fl">Startort</label>
        <input class="fi" type="text" value="Görlitz" placeholder="Stadt oder PLZ"/>
      </div>
      <div class="fg2">
        <div><label class="fl">Kraftstoff</label>
          <select class="fsel"><option>⛽ Diesel</option><option>🟢 E5</option><option>🌿 E10</option></select>
        </div>
        <div><label class="fl">Ziel</label>
          <select class="fsel" id="g-ziel"><option value="pl">🇵🇱 Polen</option><option value="cz">🇨🇿 Tschechien</option></select>
        </div>
      </div>
      <div>
        <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:7px">
          <label class="fl" style="margin:0">Tankmenge</label>
          <span style="font-size:24px;font-weight:900;letter-spacing:-1px"><span id="g-lit">60</span> <sup style="font-size:13px;color:var(--muted)">L</sup></span>
        </div>
        <input type="range" class="frange" min="10" max="120" value="60" oninput="glit(this.value)"/>
      </div>
      <div class="fg2">
        <div><label class="fl">Verbrauch L/100</label><input class="fi" id="g-use" type="number" value="7" min="3" max="25" oninput="gcalc()"/></div>
        <div><label class="fl">Entfernung km</label><input class="fi" id="g-km" type="number" value="8" min="1" max="200" oninput="gcalc()"/></div>
      </div>
      <div class="rhero">
        <div class="rlabel" id="g-status">✅ LOHNT SICH</div>
        <div class="rnum" id="g-net">7,20 €</div>
        <div class="rsub">Netto-Ersparnis nach Fahrtkosten</div>
        <div class="rdets">
          <div class="rdet">Brutto<strong id="g-gross">8,40 €</strong></div>
          <div class="rdet">Fahrtkosten<strong id="g-cost" style="color:#fca5a5">-1,20 €</strong></div>
          <div class="rdet">Break-even<strong id="g-be">ab 9L</strong></div>
        </div>
      </div>
      <div class="cmp">
        <div class="cmp-row"><div class="cflag">🇩🇪</div><div class="cn"><b>Shell Görlitz (DE)</b><small>📍 1,2 km</small></div><div class="cprice">1,64°</div><div style="font:700 10px var(--mono);color:var(--muted);margin-left:4px">€/L</div></div>
        <div class="cmp-row"><div class="cflag">🇵🇱</div><div class="cn"><b>Citronex Zgorzelec (PL)</b><small>📍 8,4 km</small></div><div class="cprice" style="color:var(--green)">1,40°</div><span class="csave good" style="margin-left:4px">-0,24</span></div>
      </div>
      <div style="padding:10px 12px;border-radius:13px;border:1px solid rgba(255,171,0,.18);background:rgba(255,171,0,.07);font-size:12px;color:var(--muted)">
        💡 <strong style="color:#fbbf24">Tipp:</strong> +20L Reservekanister = zusätzlich <strong style="color:#fbbf24">4,80 €</strong> sparen
      </div>
    </div>

    <!-- TAB: Steuervergleich -->
    <div class="tcontent" id="tab-tax">
      <div class="fg2">
        <div><label class="fl">Kraftstoff</label>
          <select class="fsel" id="t-fuel" onchange="tcalc()">
            <option value="diesel">Diesel</option>
            <option value="e5">Super E5</option>
            <option value="e10">Super E10</option>
            <option value="lpg">LPG</option>
          </select>
        </div>
        <div><label class="fl">Liter</label>
          <input class="fi" id="t-lit" type="number" value="60" min="1" max="200" oninput="tcalc()"/>
        </div>
      </div>
      <div id="t-hero" style="padding:14px;border-radius:16px;border:1px solid rgba(0,230,118,.2);background:rgba(0,230,118,.07)">
        <div style="font:800 9px var(--mono);letter-spacing:2px;color:var(--green);margin-bottom:6px">PRO LITER DIESEL</div>
        <div id="t-hl" style="font-size:15px;font-weight:900;line-height:1.3">Polen ist <strong style="color:var(--green)">0,78 €/L</strong> günstiger als Deutschland.<br><span style="font-weight:700;color:var(--muted);font-size:13px">Bei 60L = <strong style="color:var(--green)">46,80 € Ersparnis</strong></span></div>
      </div>
      <div class="tbar-row" id="t-bars">
        <!-- rendered by JS -->
      </div>
      <div style="padding:10px 12px;border-radius:13px;border:1px solid var(--rim);background:rgba(255,255,255,.03);font-size:12px;color:var(--muted);line-height:1.5">
        🇩🇪 Deutschland: <strong style="color:var(--text)">Energiesteuer + CO₂-Abgabe + MwSt.</strong> machen über 40% des Preises aus.
      </div>
      <button id="t-detail-btn" onclick="toggleTaxDetail()" style="width:100%;height:40px;border-radius:12px;border:1px solid var(--rim);background:rgba(255,255,255,.05);color:var(--text);font:800 13px var(--sans)">Details anzeigen</button>
      <div id="t-detail" style="display:none;border-radius:14px;border:1px solid var(--rim);background:rgba(255,255,255,.03);overflow:hidden">
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;padding:9px 12px;border-bottom:1px solid var(--rim);font:800 10px var(--mono);color:var(--faint)"><span>Posten</span><span>DE</span><span>PL</span><span>CZ</span></div>
        <div id="t-rows"></div>
      </div>
    </div>

    <!-- TAB: E-Auto -->
    <div class="tcontent" id="tab-ev">
      <div class="fg2">
        <div><label class="fl">Strecke km</label><input class="fi" id="ev-km" type="number" value="200" min="1" oninput="evcalc()"/></div>
        <div><label class="fl">kWh/100 km</label><input class="fi" id="ev-kwh" type="number" value="18" min="5" max="50" step=".5" oninput="evcalc()"/></div>
      </div>
      <div class="fg2">
        <div><label class="fl">Strompreis €/kWh</label><input class="fi" id="ev-price" type="number" value="0.32" step="0.01" min="0.05" oninput="evcalc()"/></div>
        <div><label class="fl">L/100 km (Verbrenner)</label><input class="fi" id="ev-lkm" type="number" value="7" min="3" max="25" step=".5" oninput="evcalc()"/></div>
      </div>
      <div class="fg2">
        <div><label class="fl">Vergleichskraftstoff</label>
          <select class="fsel" id="ev-fuel" onchange="evcalc()"><option>Diesel</option><option>E5</option><option>E10</option></select>
        </div>
        <div><label class="fl">Vergleichspreis</label>
          <select class="fsel" id="ev-country" onchange="evcalc()">
            <option value="pl">🇵🇱 PL-Preis</option>
            <option value="de">🇩🇪 DE-Preis</option>
            <option value="cz">🇨🇿 CZ-Preis</option>
          </select>
        </div>
      </div>
      <div class="ev-result">
        <div class="ev-vs">
          <div class="ev-item">
            <div class="ev-item-label">⚡ E-Auto</div>
            <div class="ev-item-val" id="ev-cost" style="color:var(--cyan)">–</div>
            <div style="font-size:10px;color:var(--muted);margin-top:3px" id="ev-kwh-total">–</div>
          </div>
          <div class="ev-vs-sep">vs</div>
          <div class="ev-item">
            <div class="ev-item-label">🛢 Verbrenner</div>
            <div class="ev-item-val" id="ev-fuel-cost">–</div>
            <div style="font-size:10px;color:var(--muted);margin-top:3px" id="ev-fuel-total">–</div>
          </div>
        </div>
        <div style="text-align:center">
          <div class="ev-diff" id="ev-diff-badge" style="margin-top:12px">–</div>
          <div style="font-size:11px;color:var(--muted);margin-top:6px" id="ev-story">Trage Strompreis ein um zu vergleichen.</div>
        </div>
      </div>
      <div class="ev-note">⚡ <strong style="color:#fbbf24">Tipp:</strong> Hausstrom (0,32 €/kWh) vs. Schnelllader (0,59-0,79 €/kWh) macht den entscheidenden Unterschied.</div>
    </div>

  </div><!-- /pbody -->
</div>

<!-- KI SIDE PANEL -->
<div class="side-panel" id="panel-ki">
  <div class="pnl-head">
    <div><h2>KI-Assistent</h2><p>Dein smarter Berater</p></div>
    <button class="pclose" onclick="cp('ki')">×</button>
  </div>
  <div class="ki-msgs" id="ki-msgs">
    <div style="text-align:center;padding:14px 0">
      <div style="width:50px;height:50px;border-radius:15px;background:linear-gradient(135deg,#00e5ff,#7c4dff);display:grid;place-items:center;font-size:24px;margin:0 auto 10px">🤖</div>
      <div style="font:900 16px var(--sans);margin-bottom:4px">BestPriceTank KI</div>
      <div style="color:var(--muted);font-size:12px;max-width:280px;margin:0 auto">Frag mich alles — Preise, Wetter, Baustellen, ob sich die Grenzfahrt lohnt.</div>
    </div>
    <div class="mu">Lohnt sich Polen heute? Ich komme aus Görlitz, 60L Diesel.</div>
    <div class="ma"><div class="mai"><div class="mah"><div class="mav">🤖</div><div class="man">BestPriceTank KI</div></div><div class="mat"><strong>Ja, definitiv! 🇵🇱</strong><br><br>Netto-Ersparnis nach Fahrtkosten: <strong style="color:var(--green)">7,20 €</strong>.</div><div class="mfs"><div class="mf"><div class="mfi" style="background:rgba(0,230,118,.15)">⛽</div>Citronex Zgorzelec · <b style="color:var(--green)">1,40 €/L</b></div><div class="mf"><div class="mfi" style="background:rgba(68,138,255,.15)">📍</div>8,4 km · 10 Min Fahrt</div><div class="mf"><div class="mfi" style="background:rgba(255,171,0,.15)">🌤</div>18°C · kein Stau · freie Fahrt</div></div></div></div>
  </div>
  <div class="ki-inp">
    <div class="kibar">
      <input type="text" id="ki-input" placeholder="Frag mich etwas..." onkeydown="if(event.key==='Enter')sendKI()"/>
      <button class="kimic">🎙️</button>
      <button class="kisend" onclick="sendKI()">➤</button>
    </div>
    <div class="qqs">
      <button class="qq" onclick="askKI('Wie ist das Wetter an der Grenze?')">🌤 Wetter</button>
      <button class="qq" onclick="askKI('Gibt es Baustellen nach Polen?')">🚧 Baustellen</button>
      <button class="qq" onclick="askKI('Lohnt sich Tschechien heute?')">🇨🇿 CZ-Check</button>
      <button class="qq" onclick="askKI('Wann tanken am günstigsten?')">📊 Preistrend</button>
      <button class="qq" onclick="askKI('Mit 20L Kanister, was spare ich?')">🪣 Kanister</button>
    </div>
  </div>
</div>

<!-- Leaflet loaded dynamically below -->
<script>
// ═══ DATA ═══
const PRICES={
  diesel:{de:1.649,pl:1.440,cz:1.477,label:'Diesel'},
  e5:{de:1.699,pl:1.479,cz:1.497,label:'Super E5'},
  e10:{de:1.669,pl:1.459,cz:1.487,label:'Super E10'},
  lpg:{de:0.979,pl:0.937,cz:0.813,label:'LPG'}
};
const TAX={
  diesel:{de:{p:2.359,net:1.366,eng:.4704,co2:.1458,vat:.3766},pl:{p:1.577,net:1.167,eng:.0753,co2:.040,vat:.2949},cz:{p:1.597,net:1.192,eng:.0780,co2:.050,vat:.2772}},
  e5:{de:{p:2.199,net:1.250,eng:.6545,co2:.120,vat:.1745},pl:{p:1.439,net:1.065,eng:.080,co2:.035,vat:.259},cz:{p:1.637,net:1.210,eng:.085,co2:.040,vat:.302}},
  e10:{de:{p:2.169,net:1.225,eng:.6545,co2:.115,vat:.1745},pl:{p:1.419,net:1.050,eng:.080,co2:.035,vat:.254},cz:{p:1.637,net:1.210,eng:.085,co2:.040,vat:.302}},
  lpg:{de:{p:.979,net:.620,eng:.180,co2:.045,vat:.134},pl:{p:.927,net:.710,eng:.040,co2:.018,vat:.159},cz:{p:.812,net:.620,eng:.035,co2:.016,vat:.141}}
};
const STATIONS=[
  {id:'citronex',name:'Citronex I, Zgorzelec',country:'pl',dist:8.4,lat:51.1517,lng:15.0055,d:1.440,e5:1.479,e10:1.459,lpg:.937,logo:'C',save:'+8,40€',best:true},
  {id:'abtank',name:'AB Tank Sieniawka',country:'pl',dist:7.8,lat:51.0720,lng:14.8620,d:1.462,e5:1.495,e10:1.475,lpg:.937,logo:'AB',save:'+6,80€',best:false},
  {id:'orlen',name:'ORLEN Bogatynia',country:'pl',dist:9.1,lat:50.9320,lng:14.9680,d:1.573,e5:1.602,e10:1.580,lpg:.952,logo:'O',save:'+2,88€',best:false},
  {id:'shell',name:'Shell Görlitz',country:'de',dist:1.2,lat:51.1543,lng:14.9888,d:1.649,e5:1.699,e10:1.669,lpg:.979,logo:'🐚',save:'Referenz',best:false},
  {id:'total',name:'TotalEnergies Görlitz',country:'de',dist:2.8,lat:51.1597,lng:14.9853,d:1.659,e5:1.709,e10:1.679,lpg:.989,logo:'T',save:'–',best:false},
  {id:'mol',name:'MOL Hrádek n.N.',country:'cz',dist:18.5,lat:50.8543,lng:14.8455,d:1.477,e5:1.497,e10:1.487,lpg:.813,logo:'M',save:'+5,16€',best:false},
  {id:'eurooil',name:'EuroOil Hrádek',country:'cz',dist:19.2,lat:50.8559,lng:14.8464,d:1.497,e5:1.517,e10:1.507,lpg:.829,logo:'E',save:'+4,56€',best:false},
];

// ═══ MAP — SVG primary, Leaflet upgrade when online ═══
let map=null;

// Always start with SVG map
function initMap(){
  // SVG map is already in HTML — just try Leaflet upgrade
  upgradeToLeaflet();
  updateBubblePrices();
}
function updateBubblePrices(){
  // Update bubble prices from STATIONS data
  STATIONS.forEach(s=>{
    const el=document.getElementById('bub-'+s.id+'-price');
    if(el) el.textContent=s.d.toFixed(3).replace('.',',')+'°';
  });
}

function upgradeToLeaflet(){
  // Leaflet upgrade disabled in prototype (SVG map runs error-free everywhere)
  // Will be enabled on Netlify deployment with full CDN access
  console.log('ℹ️ SVG-Karte aktiv. Auf Netlify: echte Leaflet-Karte.');
}
// SVG map is now static HTML — no JS injection needed
  };
  STATIONS.forEach(s=>{
    const pos=positions[s.id];if(!pos)return;
    const div=document.createElement('div');
    div.className='bub bub-'+s.country+' '+(s.best?'bub-best':'');
    div.style.cssText=`position:absolute;left:${pos.left};top:${pos.top};animation-delay:${(Math.random()*2).toFixed(1)}s;cursor:pointer;z-index:10`;
    div.onclick=()=>openStation(s.id);
    div.innerHTML=`<div class="bub-logo">${s.logo}</div>${s.d.toFixed(3).replace('.',',')}°`;
    mapEl.style.position='relative';
    mapEl.appendChild(div);
  });
}

// ═══ NAVIGATION ═══
let currentView='home';
const navMap={home:'Start',stations:'Tankstellen',rechner:'Sparen',ki:'KI-Assist'};

function sv(view){
  closePanels(true);
  currentView=view;
  // Header
  document.querySelectorAll('.hbtn').forEach(b=>b.classList.toggle('on',b.textContent.trim()===navMap[view]));
  // Dock
  document.querySelectorAll('.dbtn').forEach(b=>b.classList.remove('on'));
  const d=document.getElementById('d-'+view);if(d)d.classList.add('on');
  // AI card
  const aic=document.getElementById('aic');
  if(view==='home'){
    aic.style.display='';setTimeout(()=>{aic.style.opacity='1';aic.style.transform='none'},10);
  }else{
    aic.style.opacity='0';aic.style.transform='translateX(-24px)';
    setTimeout(()=>aic.style.display='none',280);
  }
  // Panels
  if(view==='ki'){try{checkFirstVisit();}catch(e){}}
  if(['stations','rechner','ki'].includes(view)){
    setTimeout(()=>openPanel(view),30);
  }
  setTimeout(()=>{try{if(map&&map.invalidateSize)map.invalidateSize();}catch(e){}},300);
}

function openPanel(name){
  const p=document.getElementById('panel-'+name);
  if(p){p.classList.add('open');document.getElementById('dim').classList.add('show');}
}
function cp(name){
  const p=document.getElementById('panel-'+name);
  if(p){p.classList.remove('open');}
  document.getElementById('dim').classList.remove('show');
  // Back to home
  document.querySelectorAll('.dbtn').forEach(b=>b.classList.remove('on'));
  document.getElementById('d-home').classList.add('on');
  document.querySelectorAll('.hbtn').forEach(b=>b.classList.toggle('on',b.textContent.trim()==='Start'));
  const aic=document.getElementById('aic');
  aic.style.display='';aic.style.opacity='1';aic.style.transform='none';
  currentView='home';
}
function closePanels(silent){
  ['stations','rechner','ki','community'].forEach(n=>{
    const p=document.getElementById('panel-'+n);
    if(p)p.classList.remove('open');
  });
  if(!silent){
    document.getElementById('dim').classList.remove('show');
    document.querySelectorAll('.dbtn').forEach(b=>b.classList.remove('on'));
    document.getElementById('d-home').classList.add('on');
    document.querySelectorAll('.hbtn').forEach(b=>b.classList.toggle('on',b.textContent.trim()==='Start'));
    const aic=document.getElementById('aic');
    aic.style.display='';aic.style.opacity='1';aic.style.transform='none';
    currentView='home';
  }
  closeStation(true);
}

// ═══ STATION DETAIL ═══
function openStation(id){
  const s=STATIONS.find(x=>x.id===id);if(!s)return;
  const colors={pl:'rgba(0,200,83,.18)',de:'rgba(68,138,255,.18)',cz:'rgba(255,171,0,.14)'};
  document.getElementById('sp-logo').textContent=s.logo;
  document.getElementById('sp-logo').style.background=colors[s.country]||'rgba(255,255,255,.1)';
  document.getElementById('sp-name').textContent=s.name;
  document.getElementById('sp-dist').textContent=s.dist.toFixed(1)+' km entfernt';
  document.getElementById('spd').textContent=s.d.toFixed(3).replace('.',',')+'°';
  document.getElementById('spe5').textContent=s.e5.toFixed(3).replace('.',',')+'°';
  document.getElementById('spe10').textContent=s.e10.toFixed(3).replace('.',',')+'°';
  document.getElementById('splpg').textContent=s.lpg.toFixed(3).replace('.',',')+'°';
  document.getElementById('spsave').textContent=s.save;
  document.getElementById('spdist2').textContent=s.dist.toFixed(1)+' km';
  document.getElementById('spanel').classList.add('open');
}
function closeStation(silent){document.getElementById('spanel').classList.remove('open')}

// ═══ TABS ═══
function showTab(tab){
  document.querySelectorAll('.tcontent').forEach(el=>el.classList.remove('on'));
  document.querySelectorAll('.tab').forEach(b=>b.classList.remove('on'));
  document.getElementById('tab-'+tab).classList.add('on');
  const map2={border:0,tax:1,ev:2};
  document.querySelectorAll('.tab')[map2[tab]].classList.add('on');
  if(tab==='tax')tcalc();
  if(tab==='ev')evcalc();
}

// ═══ GRENZRECHNER ═══
function money(v){return v.toLocaleString('de-DE',{minimumFractionDigits:2,maximumFractionDigits:2})+'€'}
function glit(v){document.getElementById('g-lit').textContent=v;gcalc()}
function gcalc(){
  const lit=+(document.getElementById('g-lit').textContent)||60;
  const use=+(document.getElementById('g-use').value)||7;
  const km=+(document.getElementById('g-km').value)||8;
  const ziel=document.getElementById('g-ziel').value;
  const dePl=PRICES.diesel.de-PRICES.diesel[ziel];
  const gross=dePl*lit;
  const cost=(km*2/100)*use*PRICES.diesel.de;
  const net=gross-cost;
  const be=dePl>0?Math.ceil(cost/dePl):0;
  document.getElementById('g-gross').textContent=money(gross);
  document.getElementById('g-cost').textContent='-'+money(cost);
  document.getElementById('g-net').textContent=money(Math.max(0,net));
  document.getElementById('g-be').textContent='ab '+be+'L';
  document.getElementById('g-status').textContent=net>15?'✅ LOHNT SICH KLAR':net>5?'✅ LOHNT SICH':net>0?'🟡 LOHNT KNAPP':'🔴 LOHNT NICHT';
}

// ═══ STEUERVERGLEICH ═══
const euro3=v=>v.toFixed(3).replace('.',',')+'€';
function tcalc(){
  const fuel=document.getElementById('t-fuel').value;
  const lit=+(document.getElementById('t-lit').value)||60;
  const td=TAX[fuel];if(!td)return;
  const diff=(td.de.p-td.pl.p);
  const diffCz=(td.de.p-td.cz.p);
  document.getElementById('t-hl').innerHTML=
    `Polen ist <strong style="color:var(--green)">${euro3(diff)}/L</strong> günstiger als Deutschland.<br>
    <span style="font-weight:700;color:var(--muted);font-size:13px">Bei ${lit}L = <strong style="color:var(--green)">${money(diff*lit)}</strong> Ersparnis · CZ ${money(diffCz*lit)}</span>`;
  // Bars
  const maxP=Math.max(td.de.p,td.pl.p,td.cz.p);
  const bars=[
    {flag:'🇩🇪',name:'Deutschland',t:td.de,col:'#448aff'},
    {flag:'🇵🇱',name:'Polen',t:td.pl,col:'#00e676'},
    {flag:'🇨🇿',name:'Tschechien',t:td.cz,col:'#ffab00'}
  ];
  document.getElementById('t-bars').innerHTML=bars.map(b=>{
    const netPct=(b.t.net/b.t.p*100).toFixed(0);
    const taxPct=(100-netPct);
    return`<div class="tbar">
      <div class="tbar-label">
        <div class="tbar-name">${b.flag} <span style="font-weight:900">${b.name}</span></div>
        <div class="tbar-price" style="color:${b.col}">${euro3(b.t.p)}</div>
      </div>
      <div class="tbar-track">
        <div class="tbar-net" style="width:${netPct}%"></div>
        <div class="tbar-tax" style="width:${taxPct}%"></div>
      </div>
      <div class="tbar-meta">Netto ${euro3(b.t.net)} · Abgaben ${euro3(b.t.p-b.t.net)}</div>
    </div>`;
  }).join('');
  // Detail rows
  const rows=[
    {label:'Netto/L',vals:[td.de.net,td.pl.net,td.cz.net]},
    {label:'Energiesteuer/L',vals:[td.de.eng,td.pl.eng,td.cz.eng]},
    {label:'CO₂-Abgabe/L',vals:[td.de.co2,td.pl.co2,td.cz.co2]},
    {label:'MwSt./L',vals:[td.de.vat,td.pl.vat,td.cz.vat]},
  ];
  document.getElementById('t-rows').innerHTML=rows.map(r=>
    `<div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;padding:8px 12px;border-bottom:1px solid var(--rim);font-size:12px">
      <span style="color:var(--muted)">${r.label}</span>
      <span style="font-weight:800">${euro3(r.vals[0])}</span>
      <span style="font-weight:800;color:var(--green)">${euro3(r.vals[1])}</span>
      <span style="font-weight:800;color:var(--amber)">${euro3(r.vals[2])}</span>
    </div>`
  ).join('');
}
function toggleTaxDetail(){
  const d=document.getElementById('t-detail');
  const btn=document.getElementById('t-detail-btn');
  if(d.style.display==='none'){d.style.display='block';btn.textContent='Details ausblenden';}
  else{d.style.display='none';btn.textContent='Details anzeigen';}
}

// ═══ EV RECHNER ═══
function evcalc(){
  const km=+(document.getElementById('ev-km').value)||200;
  const kwh=+(document.getElementById('ev-kwh').value)||18;
  const price=+(document.getElementById('ev-price').value)||0.32;
  const lkm=+(document.getElementById('ev-lkm').value)||7;
  const country=document.getElementById('ev-country').value;
  const fuel=document.getElementById('ev-fuel').value.toLowerCase().replace(' ','');
  const fuelKey=fuel==='supere5'?'e5':fuel==='supere10'?'e10':'diesel';
  const fuelPrice=PRICES[fuelKey]?.[country]||PRICES.diesel[country];

  const evTotal=(km/100)*kwh;
  const evCost=evTotal*price;
  const fuelTotal=(km/100)*lkm;
  const fuelCost=fuelTotal*fuelPrice;
  const diff=fuelCost-evCost;
  const good=diff>0;

  document.getElementById('ev-cost').textContent=money(evCost);
  document.getElementById('ev-kwh-total').textContent=evTotal.toFixed(1)+' kWh';
  document.getElementById('ev-fuel-cost').textContent=money(fuelCost);
  document.getElementById('ev-fuel-total').textContent=fuelTotal.toFixed(1)+' L';
  const badge=document.getElementById('ev-diff-badge');
  badge.textContent=(good?'✅ E-Auto spart ':'🔴 Verbrenner spart ')+(good?'+':'')+money(Math.abs(diff));
  badge.className='ev-diff '+(good?'ev-good':'ev-bad');
  document.getElementById('ev-story').textContent=good
    ?`Auf ${km} km ist das E-Auto ${money(diff)} günstiger als ${PRICES[fuelKey].label} zum ${country.toUpperCase()}-Preis (${euro3(fuelPrice)}).`
    :`Auf ${km} km ist der Verbrenner ${money(Math.abs(diff))} günstiger. Schnellladen kann teuer werden.`;
}

// ═══ KI CHAT ═══
// ═══ USER NAME (localStorage) ═══
let userName = localStorage.getItem('bpt_userName') || '';
function getUserName(){ return userName || 'Fahrer'; }
function setUserName(name){
  userName = name.trim();
  if(userName) localStorage.setItem('bpt_userName', userName);
}
function checkFirstVisit(){
  if(!userName){
    setTimeout(()=>{
      const msgs = document.getElementById('ki-msgs');
      if(!msgs) return;
      const msg = document.createElement('div');
      msg.className='ma';
      msg.innerHTML=`<div class="mai"><div class="mah"><div class="mav">🤖</div><div class="man">BestPriceTank KI</div></div>
        <div class="mat">Willkommen! Wie soll ich dich nennen? 👋</div></div>`;
      msgs.appendChild(msg);
      msgs.scrollTop = msgs.scrollHeight;
      // Listen for name response
      window._awaitingName = true;
    }, 500);
  } else {
    setTimeout(()=>{
      const msgs = document.getElementById('ki-msgs');
      if(!msgs) return;
      // Replace intro text with personalized greeting
      const intro = msgs.querySelector('div[style*="text-align:center"]');
      if(intro){
        const h = intro.querySelector('div:nth-child(2)');
        if(h) h.textContent = 'Hallo, '+userName+'! 👋';
      }
    }, 300);
  }
}

// Topic filter - only fuel/weather/traffic
const ALLOWED_TOPICS = ['preis','tank','diesel','e5','e10','lpg','sprit','liter','euro','günstig','billig','spar','grenze','grenz','fahrt','km','kilometer','entfern','rout','polsk','tschech','görlitz','zgorzelec','hrádek','wetter','regen','wind','temperatur','°c','stau','verkehr','baust','sperrung','wartezeit','kanister','verbrauch','lohn','e-auto','elektro','kwh','laden','strom'];
function isAllowedTopic(q){
  const ql = q.toLowerCase();
  return ALLOWED_TOPICS.some(t => ql.includes(t));
}

const kiR={
  wetter:'🌤 <strong>Grenzwetter heute:</strong><br><br>Görlitz: 18°C, leicht bewölkt<br>Zgorzelec: 18°C, leicht bewölkt<br>Hrádek: 17°C, bedeckt<br><br>✅ Keine Warnungen. Gute Fahrtbedingungen für beide Grenzrouten.',
  baust:'🚧 <strong>Baustellen heute:</strong><br><br>✅ B115 Görlitz → Grenze: frei<br>✅ A4 Richtung Polen: keine Einschränkungen<br>⚠️ B178 bei Zittau: Engstelle (~10 Min)',
  cz:'🇨🇿 <strong>Tschechien heute:</strong><br><br>MOL Hrádek: <strong style="color:#fcd34d">1,477 €/L</strong> Diesel<br>Netto-Ersparnis: ca. <strong style="color:#fcd34d">4,80 €</strong> bei 60L<br>Entfernung: 18,5 km<br><br>💡 PL ist günstiger, aber CZ lohnt sich wenn du sowieso Richtung Zittau fährst.',
  trend:'📊 <strong>Preistrend:</strong><br><br>🇵🇱 Polen: stabil seit 3 Tagen<br>🇨🇿 Tschechien: gestern -0,02 €/L<br>🇩🇪 Deutschland: leichte Schwankungen<br><br>💡 Heute ist ein überdurchschnittlich guter Tag zum Tanken in Polen.',
  kanister:'🪣 <strong>Mit 20L Reservekanister:</strong><br><br>Gesamtmenge: 80L<br>Brutto: <strong style="color:var(--green)">11,52 €</strong><br>Fahrtkosten: ca. -1,20 €<br>Netto: <strong style="color:var(--green)">10,32 €</strong><br><br>⚠️ Max. 60L Kraftstoff in Kanistern erlaubt. Zulässige Behälter nutzen.',
  default:'Basierend auf aktuellen Live-Daten empfehle ich heute <strong style="color:var(--green)">Citronex Zgorzelec</strong> mit 1,40 €/L Diesel. Netto-Ersparnis: <strong style="color:var(--green)">7,20 €</strong> bei 60L. Soll ich die Route berechnen?'
};
function askKI(q){document.getElementById('ki-input').value=q;sendKI();if(currentView!=='ki')sv('ki')}
async function sendKI(){
  const inp=document.getElementById('ki-input');
  const q=(inp.value||'').trim();if(!q)return;
  inp.value='';
  const msgs=document.getElementById('ki-msgs');

  // Handle name collection
  if(window._awaitingName){
    setUserName(q);
    window._awaitingName=false;
    const um=document.createElement('div');um.className='mu';um.textContent=q;msgs.appendChild(um);
    const am=document.createElement('div');am.className='ma';
    am.innerHTML=`<div class="mai"><div class="mah"><div class="mav">🤖</div><div class="man">BestPriceTank KI</div></div>
      <div class="mat">Super, <strong>${q}</strong>! 🎉 Ich helfe dir mit Spritpreisen, Wetter und Stau im Dreiländereck. Frag einfach drauf los!</div></div>`;
    msgs.appendChild(am);msgs.scrollTop=msgs.scrollHeight;
    return;
  }

  const um=document.createElement('div');um.className='mu';um.textContent=q;msgs.appendChild(um);
  const t=document.createElement('div');t.className='ma';
  t.innerHTML='<div class="typing"><div class="td"></div><div class="td"></div><div class="td"></div></div>';
  msgs.appendChild(t);msgs.scrollTop=msgs.scrollHeight;

  // ── Echte GPT-4o-mini API via Netlify Function ──
  try{
    const p=PRICES.diesel;
    const res=await fetch('/.netlify/functions/ki-chat',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        question:q,
        userName:getUserName(),
        prices:{
          de:p.de.toFixed(3).replace('.',','),
          pl:p.pl.toFixed(3).replace('.',','),
          cz:p.cz.toFixed(3).replace('.',',')
        }
      })
    });
    const data=await res.json();
    t.remove();
    const am=document.createElement('div');am.className='ma';
    am.innerHTML=`<div class="mai"><div class="mah"><div class="mav">🤖</div><div class="man">BestPriceTank KI · GPT-4o-mini</div></div><div class="mat">${data.answer||'–'}</div></div>`;
    msgs.appendChild(am);msgs.scrollTop=msgs.scrollHeight;
  }catch(err){
    // Fallback: Keyword-Matching wenn Netlify Function nicht erreichbar (z.B. lokal)
    console.warn('KI API nicht erreichbar, Fallback aktiv:',err.message);
    const ql=q.toLowerCase();
    let r=kiR.default;
    if(ql.includes('wetter')||ql.includes('regen'))r=kiR.wetter;
    else if(ql.includes('baust'))r=kiR.baust;
    else if(ql.includes('tschech'))r=kiR.cz;
    else if(ql.includes('trend'))r=kiR.trend;
    else if(ql.includes('kanister'))r=kiR.kanister;
    t.remove();
    const am=document.createElement('div');am.className='ma';
    am.innerHTML=`<div class="mai"><div class="mah"><div class="mav">🤖</div><div class="man">BestPriceTank KI · Offline</div></div><div class="mat">${r}</div></div>`;
    msgs.appendChild(am);msgs.scrollTop=msgs.scrollHeight;
  }
}

// ═══ STATION LIST ═══
function renderStationList(){
  const el=document.getElementById('station-list-inner');
  const flags={de:'🇩🇪',pl:'🇵🇱',cz:'🇨🇿'};
  const colors={de:'#93c5fd',pl:'#6ee7b7',cz:'#fcd34d'};
  el.innerHTML=STATIONS.map((s,i)=>`
    <div style="display:flex;align-items:center;gap:9px;padding:11px;border-radius:14px;border:1px solid ${s.best?'rgba(0,230,118,.25)':'var(--rim)'};background:${s.best?'rgba(0,200,83,.07)':'rgba(255,255,255,.03)'};cursor:pointer" onclick="openStation('${s.id}');cp('stations')">
      <div style="width:26px;height:26px;border-radius:9px;background:${s.best?'rgba(0,230,118,.2)':'rgba(255,255,255,.06)'};display:grid;place-items:center;font:900 11px var(--mono);color:${s.best?'var(--green)':'var(--muted)'};">${i+1}</div>
      <div style="flex:1;min-width:0">
        <div style="font:800 13.5px var(--sans);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${s.name}</div>
        <div style="font-size:11px;color:var(--muted);margin-top:2px">${flags[s.country]} ${s.dist.toFixed(1)} km ${s.best?'<span style="color:var(--green)">★ Bester Preis</span>':''}</div>
      </div>
      <div style="text-align:right;flex-shrink:0">
        <div style="font:900 17px var(--mono);color:${colors[s.country]}">${s.d.toFixed(3).replace('.',',')}°</div>
        <div style="font-size:10px;color:var(--muted)">€/L ${s.save&&s.save!=='Referenz'&&s.save!=='–'?'<span style="color:var(--green)">'+s.save+'</span>':''}</div>
      </div>
    </div>
  `).join('');
}
// ═══ THEME ═══
document.getElementById('themeBtn').addEventListener('click',()=>{
  document.body.style.filter=document.body.style.filter?'':'invert(.92) hue-rotate(180deg)';
});

// Init
gcalc();tcalc();evcalc();
setTimeout(()=>{try{if(map&&map.invalidateSize)map.invalidateSize();}catch(e){}},200);
</script>
</body>
</html>
